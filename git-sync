#!/bin/sh
# Fetch and rebase the current branch, delegating conflict resolution to an agent.

set -u

merge_lock_timeout=${GIT_WORKTREE_MERGE_LOCK_TIMEOUT:-30}
case "$merge_lock_timeout" in
    ''|*[!0-9]*) merge_lock_timeout=30 ;;
esac
# Keep the value within the range supported by POSIX test and shell arithmetic.
# Strip all leading zeroes in one pass so large input stays linear.
merge_lock_timeout=$(printf '%s' "$merge_lock_timeout" | sed 's/^0*//')
[ -n "$merge_lock_timeout" ] || merge_lock_timeout=0

# POSIX guarantees support through 2147483647; cap only larger values. The
# explicit ten-digit cases avoid asking test to parse an oversized integer.
merge_lock_timeout_length=${#merge_lock_timeout}
if [ "$merge_lock_timeout_length" -gt 10 ]; then
    merge_lock_timeout=2147483647
elif [ "$merge_lock_timeout_length" -eq 10 ]; then
    case "$merge_lock_timeout" in
        [3-9]*|2[2-9]*|21[5-9]*|214[8-9]*|2147[5-9]*|214748[4-9]*|2147483[7-9]*|21474836[5-9]*|214748364[8-9]*|214749[0-9]*)
            merge_lock_timeout=2147483647
            ;;
    esac
fi

release_merge_lock() {
    if [ "${merge_lock_owned-false}" = true ]; then
        rm -f "$merge_lock"
        merge_lock_owned=false
    fi
}

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
    printf '%s\n' 'git-sync: not inside a Git work tree' >&2
    exit 1
}
cd "$repo_root" || exit 1

git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || {
    printf '%s\n' 'git-sync: could not locate the common Git directory' >&2
    exit 1
}
case "$git_common_dir" in
    /*) ;;
    *) git_common_dir="$repo_root/$git_common_dir" ;;
esac
merge_lock="$git_common_dir/git-worktree-merge.lock"
# Lock acquisition must wait: sync can be started by a merge in another
# worktree, and abandoning it would skip synchronization for that branch.
merge_lock_waited=0
while ! (set -C; : > "$merge_lock") 2>/dev/null; do
    if [ "$merge_lock_waited" -ge "$merge_lock_timeout" ]; then
        printf 'git-sync: timed out after %s seconds waiting for merge lock: %s\n' \
            "$merge_lock_timeout" "$merge_lock" >&2
        exit 1
    fi
    sleep 1
    merge_lock_waited=$((merge_lock_waited + 1))
done
merge_lock_owned=true
printf '%s\n' "$$" > "$merge_lock"
trap release_merge_lock INT TERM HUP EXIT

if ! git fetch; then
    printf '%s\n' 'git-sync: git fetch failed' >&2
    exit 1
fi

if git pull --rebase; then
    exit 0
fi

# A failed pull is not necessarily a conflict (for example, it can be caused
# by a missing upstream). Only abort and involve an agent when Git left a
# rebase/conflict state behind.
rebase_merge=$(git rev-parse --git-path rebase-merge)
rebase_apply=$(git rev-parse --git-path rebase-apply)
rebase_conflict=false
if [ -e "$rebase_merge" ] || [ -e "$rebase_apply" ]; then
    rebase_conflict=true
elif [ -n "$(git ls-files --unmerged 2>/dev/null)" ]; then
    rebase_conflict=true
fi

if [ "$rebase_conflict" != true ]; then
    printf '%s\n' 'git-sync: git pull --rebase failed without leaving a conflict to resolve' >&2
    exit 1
fi

if ! git rebase --abort; then
    printf '%s\n' 'git-sync: could not abort the conflicted rebase' >&2
    exit 1
fi

prompt=$(cat <<'TASK'
Synchronize this Git worktree with its configured upstream. Run `git pull
--rebase`. If it produces conflicts, resolve them carefully without discarding
valid local or upstream work, stage each resolution, and run `git rebase
--continue` until the rebase is complete. If Git asks for a commit message,
provide a concise appropriate one. Verify the resulting worktree is not left
in a rebase or conflict state. Do not make unrelated changes.
TASK
)

if ! command -v mswea >/dev/null 2>&1; then
    printf '%s\n' 'git-sync: mswea is required to resolve rebase conflicts' >&2
    exit 1
fi

mswea "${DEV_FLOW_MODEL:-codex:gpt-5.6-luna@high}" --yolo --exit-immediately -t "$prompt" </dev/null
