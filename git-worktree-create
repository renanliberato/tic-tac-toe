#!/bin/sh
# Create a short-lived linked worktree and enter it when this file is sourced.
# An executable child process cannot change its caller's directory; use
# `. ./git-worktree-create` when the current interactive shell must move.

set -u

main() {
    if [ "$#" -ne 0 ]; then
        printf 'Usage: ./%s\n' "$(basename "$0")" >&2
        printf '%s\n' '       . ./'"$(basename "$0")"'  # also change this shell directory' >&2
        return 2
    fi

    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
        printf '%s\n' 'git-worktree-create: not inside a Git work tree' >&2
        return 1
    }

    # The first entry is the primary checkout. This also works when the
    # command is run from an existing linked worktree.
    main_root=$(git worktree list --porcelain |
        awk '$1 == "worktree" { print substr($0, 10); exit }')
    if [ -z "$main_root" ]; then
        printf '%s\n' 'git-worktree-create: could not find the main worktree' >&2
        return 1
    fi
    cd "$main_root" || return 1

    # Use a short UUID prefix for both the worktree directory and branch. A
    # collision is unlikely, but checking both Git and the filesystem keeps the
    # helper safe even when several worktrees are created in quick succession.
    attempts=0
    while :; do
        uuid=$(uuidgen 2>/dev/null) || {
            printf '%s\n' 'git-worktree-create: could not generate a UUID' >&2
            return 1
        }
        worktree_id=$(printf '%s' "$uuid" |
            tr -d '-' | cut -c 1-6 | tr '[:upper:]' '[:lower:]')
        case "$worktree_id" in
            [0123456789abcdef][0123456789abcdef][0123456789abcdef][0123456789abcdef][0123456789abcdef][0123456789abcdef])
                ;;
            *)
                worktree_id=''
                ;;
        esac

        if [ -n "$worktree_id" ]; then
            worktree_path=$main_root/.worktrees/$worktree_id
            if [ ! -e "$worktree_path" ] &&
                ! git show-ref --verify --quiet "refs/heads/$worktree_id"; then
                break
            fi
        fi

        attempts=$((attempts + 1))
        if [ "$attempts" -ge 10 ]; then
            printf '%s\n' 'git-worktree-create: could not find an unused worktree ID' >&2
            return 1
        fi
    done

    # .worktrees is local orchestration state, not project content.
    exclude_file=$(git rev-parse --git-path info/exclude)
    if ! git check-ignore -q -- .worktrees 2>/dev/null; then
        printf '\n# git-worktree helpers\n.worktrees/\n' >> "$exclude_file"
    fi
    mkdir -p "$main_root/.worktrees" || return 1

    git worktree add -b "$worktree_id" "$worktree_path" HEAD || return 1
    cd "$worktree_path" || return 1

    printf 'Created worktree %s on branch %s\n' "$worktree_path" "$worktree_id"
    printf 'Shell directory: %s\n' "$worktree_path"
}

main "$@"
status=$?
# `return` succeeds only when this file was sourced. Otherwise fall back to
# exit, keeping normal executable invocation useful as well.
return "$status" 2>/dev/null || exit "$status"
