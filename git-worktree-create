#!/bin/sh
# Create a short-lived linked worktree.
#
# When sourced (`. ./git-worktree-create`), this file also changes the current
# shell to the new worktree. When executed, it cannot change the caller's
# directory, so it prints the path for `cd "$(./git-worktree-create)"`.

set -u

merge_lock_timeout=${GIT_WORKTREE_MERGE_LOCK_TIMEOUT:-30}
case "$merge_lock_timeout" in
    ''|*[!0-9]*) merge_lock_timeout=30 ;;
esac
# Keep the value within the range supported by POSIX test and shell arithmetic.
# Strip all leading zeroes in one pass so large input stays linear.
merge_lock_timeout=$(printf '%s' "$merge_lock_timeout" | sed 's/^0*//')
[ -n "$merge_lock_timeout" ] || merge_lock_timeout=0

# POSIX guarantees support through 2147483647; cap only larger values. The
# explicit ten-digit cases avoid asking test to parse an oversized integer.
merge_lock_timeout_length=${#merge_lock_timeout}
if [ "$merge_lock_timeout_length" -gt 10 ]; then
    merge_lock_timeout=2147483647
elif [ "$merge_lock_timeout_length" -eq 10 ]; then
    case "$merge_lock_timeout" in
        [3-9]*|2[2-9]*|21[5-9]*|214[8-9]*|2147[5-9]*|214748[4-9]*|2147483[7-9]*|21474836[5-9]*|214748364[8-9]*|214749[0-9]*)
            merge_lock_timeout=2147483647
            ;;
    esac
fi

release_merge_lock() {
    if [ "${merge_lock_owned-false}" = true ]; then
        rm -f "$merge_lock"
        merge_lock_owned=false
    fi
}

acquire_merge_lock() {
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || return 1
    case "$git_common_dir" in
        /*) ;;
        *) git_common_dir="$repo_root/$git_common_dir" ;;
    esac
    merge_lock="$git_common_dir/git-worktree-merge.lock"
    # Creation must wait for an in-progress merge instead of abandoning the
    # request when another worktree owns the shared lock.
    merge_lock_waited=0
    while ! (set -C; : > "$merge_lock") 2>/dev/null; do
        if [ "$merge_lock_waited" -ge "$merge_lock_timeout" ]; then
            printf 'git-worktree-create: timed out after %s seconds waiting for merge lock: %s\n' \
                "$merge_lock_timeout" "$merge_lock" >&2
            return 2
        fi
        sleep 1
        merge_lock_waited=$((merge_lock_waited + 1))
    done
    merge_lock_owned=true
    printf '%s\n' "$$" > "$merge_lock"
    return 0
}

main() {
    if [ "$#" -ne 0 ]; then
        printf '%s\n' 'Usage: ./git-worktree-create' >&2
        printf '%s\n' '       . ./git-worktree-create  # also change this shell directory' >&2
        return 2
    fi

    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
        printf '%s\n' 'git-worktree-create: not inside a Git work tree' >&2
        return 1
    }

    # The first entry is the primary checkout. This also works when the
    # command is run from an existing linked worktree.
    main_root=$(git worktree list --porcelain |
        awk '$1 == "worktree" { print substr($0, 10); exit }')
    if [ -z "$main_root" ]; then
        printf '%s\n' 'git-worktree-create: could not find the main worktree' >&2
        return 1
    fi
    merge_lock=''
    if acquire_merge_lock; then
        :
    else
        status=$?
        if [ "$status" -eq 1 ]; then
            printf '%s\n' 'git-worktree-create: could not locate the common Git directory' >&2
        fi
        return "$status"
    fi
    trap release_merge_lock INT TERM HUP

    cd "$main_root" || return 1

    # Use a short UUID prefix for both the worktree directory and branch. A
    # collision is unlikely, but checking both Git and the filesystem keeps the
    # helper safe even when several worktrees are created in quick succession.
    attempts=0
    while :; do
        uuid=$(uuidgen 2>/dev/null) || {
            printf '%s\n' 'git-worktree-create: could not generate a UUID' >&2
            return 1
        }
        worktree_id=$(printf '%s' "$uuid" |
            tr -d '-' | cut -c 1-6 | tr '[:upper:]' '[:lower:]')
        case "$worktree_id" in
            [0123456789abcdef][0123456789abcdef][0123456789abcdef][0123456789abcdef][0123456789abcdef][0123456789abcdef])
                ;;
            *)
                worktree_id=''
                ;;
        esac

        if [ -n "$worktree_id" ]; then
            worktree_path=$main_root/.worktrees/$worktree_id
            if [ ! -e "$worktree_path" ] &&
                ! git show-ref --verify --quiet "refs/heads/$worktree_id"; then
                break
            fi
        fi

        attempts=$((attempts + 1))
        if [ "$attempts" -ge 10 ]; then
            printf '%s\n' 'git-worktree-create: could not find an unused worktree ID' >&2
            return 1
        fi
    done

    # .worktrees is local orchestration state, not project content.
    exclude_file=$(git rev-parse --git-path info/exclude)
    if ! git check-ignore -q -- .worktrees 2>/dev/null; then
        printf '\n# git-worktree helpers\n.worktrees/\n' >> "$exclude_file"
    fi
    mkdir -p "$main_root/.worktrees" || return 1

    git worktree add -b "$worktree_id" "$worktree_path" HEAD >/dev/null || return 1
    cd "$worktree_path" || return 1

    # Keep stdout machine-readable: callers can safely use command substitution.
    printf '%s\n' "$worktree_path"
}

main "$@"
status=$?
release_merge_lock
trap - INT TERM HUP
# `return` succeeds when sourced and leaves the caller in the new worktree.
# When executed, it fails and the final `exit` returns the creation status.
return "$status" 2>/dev/null || exit "$status"
