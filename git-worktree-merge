#!/bin/sh
# Push a linked worktree, then merge it into the primary checkout.
# Source this script if the caller's shell should remain in the primary checkout.

set -u

merge_lock_timeout=${GIT_WORKTREE_MERGE_LOCK_TIMEOUT:-30}
case "$merge_lock_timeout" in
    ''|*[!0-9]*) merge_lock_timeout=30 ;;
esac
# Keep the value within the range supported by POSIX test and shell arithmetic.
# Strip all leading zeroes in one pass so large input stays linear.
merge_lock_timeout=$(printf '%s' "$merge_lock_timeout" | sed 's/^0*//')
[ -n "$merge_lock_timeout" ] || merge_lock_timeout=0

# POSIX guarantees support through 2147483647; cap only larger values. The
# explicit ten-digit cases avoid asking test to parse an oversized integer.
merge_lock_timeout_length=${#merge_lock_timeout}
if [ "$merge_lock_timeout_length" -gt 10 ]; then
    merge_lock_timeout=2147483647
elif [ "$merge_lock_timeout_length" -eq 10 ]; then
    case "$merge_lock_timeout" in
        [3-9]*|2[2-9]*|21[5-9]*|214[8-9]*|2147[5-9]*|214748[4-9]*|2147483[7-9]*|21474836[5-9]*|214748364[8-9]*|214749[0-9]*)
            merge_lock_timeout=2147483647
            ;;
    esac
fi

acquire_lock() {
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || return 1
    case "$git_common_dir" in
        /*) ;;
        *) git_common_dir="$main_root/$git_common_dir" ;;
    esac
    merge_lock="$git_common_dir/git-worktree-merge.lock"
    # Never abandon a merge because another merge is still using the shared
    # lock. Retry the atomic create until the current owner releases it.
    merge_lock_waited=0
    while ! (set -C; : > "$merge_lock") 2>/dev/null; do
        if [ "$merge_lock_waited" -ge "$merge_lock_timeout" ]; then
            printf 'git-worktree-merge: timed out after %s seconds waiting for merge lock: %s\n' \
                "$merge_lock_timeout" "$merge_lock" >&2
            return 2
        fi
        sleep 1
        merge_lock_waited=$((merge_lock_waited + 1))
    done
    merge_lock_owned=true
    printf '%s\n' "$$" > "$merge_lock"
    return 0
}

release_lock() {
    if [ "${merge_lock_owned-false}" = true ]; then
        rm -f "$merge_lock"
        merge_lock_owned=false
    fi
}

restore_primary_sync_transcript() {
    if [ -n "${primary_sync_transcript_reserve-}" ]; then
        if [ -e "$primary_sync_transcript" ]; then
            printf 'git-worktree-merge: could not restore primary-sync transcript without overwriting: %s\n' \
                "$primary_sync_transcript" >&2
            return 1
        fi
        mv -- "$primary_sync_transcript_reserve" "$primary_sync_transcript" || return 1
        primary_sync_transcript_reserve=''
    fi
}

fold_primary_sync_transcript() {
    [ -n "${primary_sync_transcript_reserve-}" ] || return 0

    base="tasks/${DEV_FLOW_TASK_ID}-session-sync-conflict-resolver"
    # Match task-session's repeat convention: promote an existing unsuffixed
    # transcript before assigning the reserved primary-sync attempt its suffix.
    existing_count=$(find tasks -type f -name "${DEV_FLOW_TASK_ID}-session-sync-conflict-resolver-[0-9][0-9].md" | wc -l | tr -d ' ')
    if [ -f "${base}.md" ]; then
        suffix=$(printf '%02d' "$((existing_count + 1))")
        mv -- "${base}.md" "${base}-${suffix}.md" || return 1
        existing_count=$((existing_count + 1))
    fi
    if [ "$existing_count" -eq 0 ]; then
        destination="${base}.md"
    else
        suffix=$(printf '%02d' "$((existing_count + 1))")
        destination="${base}-${suffix}.md"
    fi
    mv -- "$primary_sync_transcript_reserve" "$destination" || return 1
    primary_sync_transcript_reserve=''

    git add -A -- "${base}.md" "${base}"*.md || return 1
    if ! git diff --cached --quiet; then
        git commit --amend --no-edit > /dev/null || return 1
    fi
}

cleanup_worktree() {
    if ! git worktree remove --force "$repo_root"; then
        printf 'git-worktree-merge: could not remove worktree: %s\n' "$repo_root" >&2
        return 1
    fi

    # Git normally removes the checkout directory too. Remove it explicitly if
    # a Git version or filesystem leaves the now-unregistered path behind.
    if [ -e "$repo_root" ] || [ -L "$repo_root" ]; then
        if ! rm -rf "$repo_root"; then
            printf 'git-worktree-merge: could not remove worktree directory: %s\n' "$repo_root" >&2
            return 1
        fi
    fi
    if [ -e "$repo_root" ] || [ -L "$repo_root" ]; then
        printf 'git-worktree-merge: worktree directory still exists: %s\n' "$repo_root" >&2
        return 1
    fi

    # Do not leave an empty orchestration directory behind, but never remove it
    # while it contains another linked worktree (or unrelated user content).
    worktree_parent=${repo_root%/*}
    if [ "$worktree_parent" = "$main_root/.worktrees" ]; then
        rmdir "$worktree_parent" 2>/dev/null || :
    fi

    if ! git branch -d "$worktree_branch"; then
        printf 'git-worktree-merge: could not delete branch: %s\n' "$worktree_branch" >&2
        return 1
    fi
}

main() {
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
        printf '%s\n' 'git-worktree-merge: not inside a Git work tree' >&2
        return 1
    }
    worktree_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || {
        printf '%s\n' 'git-worktree-merge: worktree must be on a branch' >&2
        return 1
    }

    case "$worktree_branch" in
        [0123456789abcdefABCDEF][0123456789abcdefABCDEF][0123456789abcdefABCDEF][0123456789abcdefABCDEF][0123456789abcdefABCDEF][0123456789abcdefABCDEF])
            ;;
        *)
            printf 'git-worktree-merge: current branch is not a six-character worktree branch: %s\n' "$worktree_branch" >&2
            return 1
            ;;
    esac

    main_root=$(git worktree list --porcelain |
        awk '$1 == "worktree" { print substr($0, 10); exit }')
    if [ -z "$main_root" ]; then
        printf '%s\n' 'git-worktree-merge: could not find the main worktree' >&2
        return 1
    fi
    if [ "$repo_root" = "$main_root" ]; then
        printf '%s\n' 'git-worktree-merge: run this command from a linked worktree, not the main checkout' >&2
        return 1
    fi

    if [ ! -x "$main_root/git-sync" ]; then
        printf '%s\n' 'git-worktree-merge: git-sync is missing or not executable in the main checkout' >&2
        return 1
    fi

    # Push before entering the primary checkout. A new branch gets its
    # upstream here; subsequent invocations use the existing upstream.
    upstream=''
    if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
        git push || return 1
    else
        git push --set-upstream origin "$worktree_branch" || return 1
    fi

    cd "$main_root" || return 1
    [ -r ./task-session ] && . ./task-session
    primary_sync_snapshot=''
    primary_sync_transcript=''
    primary_sync_transcript_reserve=''
    if command -v task_session_enabled > /dev/null 2>&1 && task_session_enabled; then
        primary_sync_snapshot=$(mktemp "${TMPDIR:-/tmp}/git-worktree-merge-${DEV_FLOW_TASK_ID}.XXXXXX") || return 1
        git ls-files --others --exclude-standard -- \
            "tasks/${DEV_FLOW_TASK_ID}-session-sync-conflict-resolver"*.md > "$primary_sync_snapshot" || {
            rm -f "$primary_sync_snapshot"
            return 1
        }
    fi
    if "$main_root/git-sync"; then
        :
    else
        status=$?
        rm -f "$primary_sync_snapshot"
        return "$status"
    fi
    if [ -n "$primary_sync_snapshot" ]; then
        for transcript in $(git ls-files --others --exclude-standard -- \
            "tasks/${DEV_FLOW_TASK_ID}-session-sync-conflict-resolver"*.md); do
            if ! grep -F -x -- "$transcript" "$primary_sync_snapshot" > /dev/null; then
                primary_sync_transcript=$transcript
                break
            fi
        done
        rm -f "$primary_sync_snapshot"
        if [ -n "$primary_sync_transcript" ]; then
            primary_sync_transcript_reserve=$(mktemp "${TMPDIR:-/tmp}/git-worktree-merge-${DEV_FLOW_TASK_ID}-session.XXXXXX") || return 1
            if ! mv -- "$primary_sync_transcript" "$primary_sync_transcript_reserve"; then
                rm -f "$primary_sync_transcript_reserve"
                return 1
            fi
        fi
    fi

    # The lock lives in the common Git directory so it is shared by the
    # primary checkout and every linked worktree.
    merge_lock=''
    merge_lock_owned=false
    if acquire_lock; then
        :
    else
        status=$?
        if [ "$status" -eq 1 ]; then
            printf '%s\n' 'git-worktree-merge: could not locate the common Git directory' >&2
        fi
        restore_primary_sync_transcript || :
        return "$status"
    fi
    trap release_lock INT TERM HUP EXIT

    if ! git fetch origin "$worktree_branch"; then
        restore_primary_sync_transcript || :
        release_lock
        trap - INT TERM HUP EXIT
        return 1
    fi

    if git merge --no-edit "origin/$worktree_branch"; then
        if ! fold_primary_sync_transcript; then
            restore_primary_sync_transcript || :
            release_lock
            trap - INT TERM HUP EXIT
            return 1
        fi
        if ! cleanup_worktree; then
            release_lock
            trap - INT TERM HUP EXIT
            return 1
        fi
        printf 'Merged worktree branch %s into %s and removed the worktree\n' "$worktree_branch" "$(git branch --show-current)"
        release_lock
        trap - INT TERM HUP EXIT
        return 0
    fi

    merge_head=$(git rev-parse --git-path MERGE_HEAD)
    if [ -f "$merge_head" ] || [ -n "$(git ls-files --unmerged 2>/dev/null)" ]; then
        if ! git merge --abort; then
            restore_primary_sync_transcript || :
            printf '%s\n' 'git-worktree-merge: could not abort the conflicted merge' >&2
            release_lock
            trap - INT TERM HUP EXIT
            return 1
        fi
        prompt=$(cat <<TASK
Merge the worktree branch $worktree_branch into the primary branch in this
repository. Start by running git fetch origin $worktree_branch and then
git merge --no-edit origin/$worktree_branch. Resolve all conflicts carefully,
preserving valid work from both sides; stage the resolutions and complete the
merge. Do not discard unrelated changes. Verify that the repository is left
with the merge completed and no unmerged files.
TASK
)
        if ! command -v mswea >/dev/null 2>&1; then
            printf '%s\n' 'git-worktree-merge: mswea is required to resolve merge conflicts' >&2
            release_lock
            trap - INT TERM HUP EXIT
            return 1
        fi
        task_session merge-conflict-resolver mswea "${DEV_FLOW_MODEL:-codex:gpt-5.6-luna@high}" --yolo --exit-immediately -t "$prompt" </dev/null
        status=$?
        if [ "$status" -eq 0 ]; then
            merge_head=$(git rev-parse --git-path MERGE_HEAD)
            if [ -f "$merge_head" ] || [ -n "$(git ls-files --unmerged 2>/dev/null)" ]; then
                printf '%s\n' 'git-worktree-merge: conflict resolver did not complete the merge' >&2
                status=1
            elif task_session_enabled; then
                # The primary-sync transcript was reserved before the merge
                # so a same-named branch artifact could not block either
                # merge attempt. Fold it into the completed merge first.
                fold_primary_sync_transcript || status=1
                # This transcript is created in the primary checkout after
                # the branch merge. Fold it into the merge result instead of
                # leaving a post-merge observability-only change behind.
                if [ "$status" -eq 0 ]; then
                    git add -- "tasks/${DEV_FLOW_TASK_ID}"-session-merge-conflict-resolver* \
                        "tasks/${DEV_FLOW_TASK_ID}"-session-sync-conflict-resolver* || status=1
                fi
                if [ "$status" -eq 0 ] && ! git diff --cached --quiet; then
                    git commit --amend --no-edit >/dev/null || status=1
                fi
                if [ "$status" -eq 0 ] && ! cleanup_worktree; then
                    status=1
                fi
            elif ! cleanup_worktree; then
                status=1
            fi
        fi
        if [ "$status" -ne 0 ]; then
            restore_primary_sync_transcript || :
        fi
        release_lock
        trap - INT TERM HUP EXIT
        return "$status"
    fi

    restore_primary_sync_transcript || :
    printf '%s\n' 'git-worktree-merge: git merge failed without leaving a conflict to resolve' >&2
    release_lock
    trap - INT TERM HUP EXIT
    return 1
}

main "$@"
status=$?
return "$status" 2>/dev/null || exit "$status"
